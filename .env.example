# Example environment configuration for the RoboRef frontend.
#
# Copy this file to `.env.local` and fill in the values:
#     cp .env.example .env.local
#
# IMPORTANT: every `VITE_*` value below is INLINED INTO THE CLIENT BUNDLE at
# build time (`vite build`) — it is not read at runtime. Because the Cloudflare
# Pages deploy is a direct upload of a locally-built `dist/`, whatever is set
# here on the build machine is what ships to production. If a `VITE_*` var is
# missing at build time it becomes `undefined` in the browser (silently).
# `.env.local` is gitignored; this `.env.example` is committed as the template.

# --- Required ---------------------------------------------------------------

# Where the frontend finds the sync backend. Also the host for the RobotEvents
# proxy (`/api/robotevents/*`), which holds the RobotEvents token server-side —
# the token is no longer shipped to the browser.
VITE_REFEREE_FYI_SHARE_SERVER=https://referee-fyi-share.example.workers.dev

# --- Optional ---------------------------------------------------------------

# Override the Sentry project for error + log reporting. Inlined into the client
# bundle at build time. The app falls back to a built-in default DSN when this is
# unset, so set it only to point reporting at a DIFFERENT Sentry project. A DSN
# is designed to be public, so shipping it in browser JS is expected and safe.
VITE_SENTRY_DSN=https://examplePublicKey@oXXXXXXX.ingest.de.sentry.io/XXXXXXX

# Build variant. "STANDARD" for normal builds; "WC" enables the worlds build
# (changes sharing, shows extra info, disables some features). Default STANDARD.
VITE_REFEREE_FYI_BUILD_MODE=STANDARD

# Turn on automatic Sentry reporting in THIS environment. Production builds
# (`MODE === "production"`) enable Sentry regardless, so this only matters for
# local dev. Recommended `false` unless you are actively testing error reporting
# — dev events go to whatever project VITE_SENTRY_DSN points at.
VITE_REFEREE_FYI_ENABLE_SENTRY=false

# --- Build-time only (NOT a VITE_ var; never reaches the browser) -----------

# Used by @sentry/vite-plugin to upload source maps to Sentry during the build,
# so stack traces are de-minified in the Sentry dashboard. This is a SECRET —
# keep it out of version control. Optional; if unset, the build still succeeds
# and just skips source-map upload.
# SENTRY_AUTH_TOKEN=
