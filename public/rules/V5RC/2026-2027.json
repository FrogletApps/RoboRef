        },
        {
          "rule": "<VUR2>",
          "description": "Teams may use any official VEX Robotics products, other than the exceptions listed below",
          "link": "https://www.vexrobotics.com/override-manual#vur2"
        },
        {
          "rule": "<VUR3>",
          "description": "Fabricated Parts may be made by applying the following processes to Raw Stock",
          "link": "https://www.vexrobotics.com/override-manual#vur3"
        },
        {
          "rule": "<VUR4>",
          "description": "Fabricated Parts must be made from legal Raw Stock",
          "link": "https://www.vexrobotics.com/override-manual#vur4"
        },
        {
          "rule": "<VUR5>",
          "description": "The following material types are not considered Raw Stock",
          "link": "https://www.vexrobotics.com/override-manual#vur5"
        },
        {
          "rule": "<VUR6>",
          "description": "Fabricated Parts cannot be made from Raw Stock which poses a safety or damage risk",
